    "autoprefixer": "^10.4.16",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.462.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.2.1",
    "@supabase/supabase-js": "^2.38.5",
    "@supabase/ssr": "^0.0.10"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^8.55.0",
    "eslint-config-next": "^15.0.0",
